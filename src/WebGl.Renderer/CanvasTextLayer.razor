@namespace WebGl.Renderer

@* Read-only, natively-selectable text runs floated over the canvas -- the retained-layer sibling of
   CanvasTextOverlay (which is a single focusable <input> for EDITABLE text). Absolutely positioned:
   the consumer must place this component inside the same position:relative container as the canvas,
   and pass rects/font sizes in CSS px (backing-buffer px / DevicePixelRatio -- the same convention
   as CanvasTextOverlay). The layer itself swallows no input (pointer-events:none), so canvas
   drags/clicks pass through everywhere except directly over a text run, where pointer events
   re-enable so the browser's native selection/copy works. *@
@if (Runs is { Count: > 0 })
{
    <div class="@Class" style="position:absolute;inset:0;overflow:hidden;pointer-events:none;z-index:5;">
        @foreach (var run in Runs)
        {
            @if (run.Href is { Length: > 0 } href)
            {
                @* A hyperlink run: a real <a> so the browser owns open/new-tab/copy-link. target=_blank
                   opens a new tab; rel=noopener severs the opener reference (tabnabbing hardening). *@
                <a href="@href" target="_blank" rel="noopener" style="@RunStyle(run)">@run.Text</a>
            }
            else
            {
                <div style="@RunStyle(run)">@run.Text</div>
            }
        }
    </div>
}
